{
  "title": "Bank Core",
  "uid": "bank-core",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["bank-core"],
  "timezone": "browser",
  "time": {"from": "now-15m", "to": "now"},
  "refresh": "15s",
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{uri}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP request p95",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{uri}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM heap memory used",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap used", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM non-heap memory used",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"})", "legendFormat": "nonheap used", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM live thread count",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "targets": [
        {"expr": "jvm_threads_live_threads", "legendFormat": "threads", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Transfer outcome rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (outcome) (rate(bank_transfer_executed_total[1m]))", "legendFormat": "{{outcome}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Transfer p95 duration",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(bank_transfer_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Lock acquisition p95",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, strategy) (rate(bank_lock_acquisition_seconds_bucket[5m])))", "legendFormat": "{{strategy}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Journal verification rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (outcome) (rate(bank_journal_verification_total[1m]))", "legendFormat": "{{outcome}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Pending journals",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 32, "w": 6, "h": 6},
      "targets": [
        {"expr": "bank_journal_pending", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Total transfers",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 6, "y": 32, "w": 6, "h": 6},
      "targets": [
        {"expr": "sum(bank_transfer_executed_total)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Account suspension rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (cause) (rate(bank_account_suspended_total[1m]))", "legendFormat": "{{cause}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    }
  ]
}
